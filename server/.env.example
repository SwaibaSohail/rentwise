PORT=4000
CLIENT_URL=http://localhost:5173
# Neon connection string. Append &connect_timeout=30 so the first query after a
# cold-start (suspended compute) doesn't hit Prisma's 5s default and fail with P1001.
# e.g. postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL=
# Firebase Admin (Project settings -> Service accounts -> Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the JSON private_key value verbatim, in double quotes (keeps the \n escapes):
FIREBASE_PRIVATE_KEY=
# Stripe test secret key (Developers -> API keys -> test mode)
STRIPE_SECRET_KEY=
# Cloudinary (cloudinary.com -> Settings -> Access Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
